# Database
DATABASE_URL=postgresql+asyncpg://transcribely:devpassword@localhost:5432/transcribely
SYNC_DATABASE_URL=postgresql://transcribely:devpassword@localhost:5432/transcribely

# Redis
REDIS_URL=redis://localhost:6379/0

# S3/MinIO (local development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=transcribely-videos

# Whisper Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# JWT Secret (change in production!)
JWT_SECRET=dev-secret-change-in-production

# Frontend URL
FRONTEND_URL=http://localhost:3000

# NextAuth (frontend)
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000
